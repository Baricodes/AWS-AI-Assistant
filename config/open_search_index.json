      "s3_key": { "type": "keyword" },
      "url": { "type": "keyword" },
      "tags": { "type": "keyword" },
      "token_count": { "type": "integer" },
      "created_at": { "type": "date" },
      "updated_at": { "type": "date" }
    }
  }
